{
  "name": "media-mcp",
  "version": "0.1.9",
  "description": "MCP server for Kyle's media stack.",
  "type": "module",
  "bin": {
    "media-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "MEDIA_MCP_TRANSPORT=http tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "MEDIA_MCP_TRANSPORT=http node dist/index.js",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:http": "MEDIA_MCP_SMOKE_URL=${MEDIA_MCP_SMOKE_URL:-http://localhost:3000/mcp} tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.11"
  },
  "license": "MIT"
}

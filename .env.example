# Base URLs can be local container URLs, LAN URLs, or tunnel URLs.
# API keys come from each app's Settings -> General page.

SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

RADARR_URL=http://radarr:7878
RADARR_API_KEY=

LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=

PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

SABNZBD_URL=http://sabnzbd:8080
SABNZBD_API_KEY=

JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

BEETS_FLASK_URL=http://beets-flask:5001

SLSKD_URL=http://slskd:5030
SLSKD_API_KEY=

# Optional: comma-separated browser origins allowed to call Streamable HTTP.
# Leave unset for non-browser/local service clients.
# MEDIA_MCP_ALLOWED_ORIGINS=http://localhost:3000

# Optional: enable request/write tools such as request_movie.
# Leave unset or false for read-only/search/preview mode.
# ALLOW_REQUESTS=false

# Optional: comma-separated app names to disable even if configured.
# DISABLED_APPS=lidarr,prowlarr
